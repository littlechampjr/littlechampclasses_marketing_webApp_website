# API base URL (required on Vercel for SSR; optional locally if you use defaults).
# Local: match ../backend/.env PORT (default 4100).
NEXT_PUBLIC_API_URL=http://localhost:4100
# Production example:
# NEXT_PUBLIC_API_URL=https://littlechampjunior-backend.vercel.app

# Backend CORS: set FRONTEND_URL to your site(s), comma-separated, e.g.
# https://littlechampjunior.vercel.app,https://littlechampjunior.com,https://www.littlechampjunior.com
